{
  "name": "近似短路风险",
  "description": "一个闭合开关直接跨接在电源两端，用于触发短路风险诊断。",
  "ground": "gnd",
  "components": [
    {
      "id": "V1",
      "type": "voltage_source",
      "name": "直流电源",
      "nodes": ["n1", "gnd"],
      "params": {
        "voltage": 6.0
      }
    },
    {
      "id": "S1",
      "type": "switch",
      "name": "错误旁路开关",
      "nodes": ["n1", "gnd"],
      "params": {
        "state": "closed"
      }
    },
    {
      "id": "R1",
      "type": "resistor",
      "name": "负载电阻",
      "nodes": ["n1", "gnd"],
      "params": {
        "resistance": 100.0
      }
    }
  ]
}
