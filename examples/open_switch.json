{
  "name": "开关断开导致开路",
  "description": "电源和电阻之间存在断开的开关，用于展示开路与零电流状态。",
  "ground": "gnd",
  "components": [
    {
      "id": "V1",
      "type": "voltage_source",
      "name": "直流电源",
      "nodes": ["n1", "gnd"],
      "params": {
        "voltage": 9.0
      }
    },
    {
      "id": "S1",
      "type": "switch",
      "name": "断开的开关",
      "nodes": ["n1", "n2"],
      "params": {
        "state": "open"
      }
    },
    {
      "id": "R1",
      "type": "resistor",
      "name": "负载电阻",
      "nodes": ["n2", "gnd"],
      "params": {
        "resistance": 100.0
      }
    }
  ]
}
